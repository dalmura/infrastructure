{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "7 days",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "enabledManagers": [
    "argocd",
    "helm-values",
    "kubernetes",
    "kustomize",
    "custom.regex"
  ],
  "ignorePaths": [
    "sites/archived/**"
  ],
  "argocd": {
    "managerFilePatterns": [
      "sites/*/clusters/*/*/app/templates/*.yaml"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "sites/*/clusters/*/*/values/*/values.yaml"
    ],
    "ignorePaths": [
      "sites/*/clusters/*/*/app/**"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "sites/*/clusters/*/*/overlays/*/deployment.yaml"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "sites/*/clusters/*/*/overlays/*/kustomization.yaml"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "sites/*/clusters/*/wave-2/values/traefik-public/values.yaml"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\n\\s+version:\\s*(?<currentValue>.*)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "sites/indigo/**"
      ],
      "addLabels": [
        "site/indigo"
      ],
      "commitMessagePrefix": "[indigo] ",
      "additionalBranchPrefix": "indigo-"
    },
    {
      "matchFileNames": [
        "sites/navy/**"
      ],
      "addLabels": [
        "site/navy"
      ],
      "commitMessagePrefix": "[navy] ",
      "additionalBranchPrefix": "navy-"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "photoprism/photoprism"
      ],
      "versioning": "regex:^(?<major>\\d{2})(?<minor>\\d{2})(?<patch>\\d{2})$"
    }
  ]
}
